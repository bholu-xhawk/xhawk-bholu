{
  "name": "xhawk-bholu",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Node.js TypeScript application scaffold with Jest, ESLint, Prettier, Husky, and GitHub Actions CI.",
  "engines": {
    "node": ">=20 <21"
  },
  "scripts": {
    "dev": "node --watch --loader ts-node/esm src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "jest --passWithNoTests",
    "lint": "eslint . --ext .ts,.js",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix"
    ],
    "*.{ts,js,json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "packageManager": "npm@10",
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@typescript-eslint/eslint-plugin": "^7.12.0",
    "@typescript-eslint/parser": "^7.12.0",
    "eslint": "^9.5.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "husky": "^9.0.11",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.7",
    "prettier": "^3.3.2",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
